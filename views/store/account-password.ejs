<%- include('../partials/head', { title }) %>
<section class="auth-shell">
  <div class="auth-card">
    <p class="eyebrow">账号安全</p>
    <h1>修改登录密码</h1>
    <p class="hint">修改后，其他已登录设备会自动退出。</p>
    <form method="post" action="/account/password">
      <label for="current-password">当前密码</label>
      <input id="current-password" name="current_password" type="password" autocomplete="current-password" required>
      <label for="new-password">新密码</label>
      <input id="new-password" name="new_password" type="password" autocomplete="new-password" minlength="8" required>
      <label for="new-password-confirm">确认新密码</label>
      <input id="new-password-confirm" name="password_confirm" type="password" autocomplete="new-password" minlength="8" required>
      <button type="submit">更新密码</button>
    </form>
  </div>
</section>
<%- include('../partials/foot') %>
