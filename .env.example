# Application
NODE_ENV=development
APP_NAME=期末资料自动售卖
PORT=3000
TZ=Asia/Shanghai

# Security
# Production requires at least 32 random characters.
SESSION_SECRET=
# Used only when the admins table is empty on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Storage and order behavior
DATABASE_PATH=data/app.db
ORDER_EXPIRE_MINUTES=30
USER_LOGIN_DAYS=30

# OCR
# Linux example:
# OCR_COMMAND=tesseract {file} stdout -l chi_sim+eng
# Leave empty on Windows to use scripts/windows-ocr.ps1.
OCR_COMMAND=
