# 复制为 .env 后填写真实值；不要把 .env 提交到 Git。
APP_NAME=期末资料售卖
PORT=3000
NODE_ENV=development

# 正式部署必须使用至少 32 位的随机值，禁止使用示例或默认字符串。
SESSION_SECRET=replace-with-at-least-32-random-characters
DATABASE_PATH=data/app.db

# 首次启动时必须提供。管理员密码至少 12 位。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters

# 仅当应用位于一层可信反向代理（如 Nginx）之后时设为 1。
TRUST_PROXY=0

ORDER_EXPIRE_MINUTES=30
USER_LOGIN_DAYS=30

# OCR 只用于辅助人工审核，识别结果不能作为真实付款凭证。
OCR_COMMAND=